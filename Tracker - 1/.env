APP_NAME=Trackr
APP_VERSION=1.0.0
DEBUG=false

# ⚠️  DO NOT commit real credentials.
# Copy .env.example → .env and fill in your own values.
MONGO_URI=mongodb://localhost:27017/?replicaSet=rs0
MONGO_DB=trackr_dev
MONGO_TRANSACTIONS_ENABLED=true

# Generate a real secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_real_32_plus_char_secret_before_running
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=CHANGE_ME
# Set for local MinIO: AWS_ENDPOINT_URL=http://localhost:9100
AWS_ENDPOINT_URL=
