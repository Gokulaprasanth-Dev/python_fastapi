APP_NAME=Trackr
APP_VERSION=1.0.0
DEBUG=false

# MongoDB
# Use an Atlas URI for production (supports transactions).
# For local dev with a standalone mongod, set MONGO_TRANSACTIONS_ENABLED=false.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGO_DB=trackr_dev

# Set to false if running against a standalone mongod (no replica set).
# When false, NoOpUnitOfWork is used and writes are NOT atomic.
MONGO_TRANSACTIONS_ENABLED=true

# JWT — generate a strong random secret before deploying:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-minimum-32-chars-xxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=<your-bucket-name>
# Leave blank for real AWS S3. Set to MinIO endpoint for local dev:
# AWS_ENDPOINT_URL=http://localhost:9002
AWS_ENDPOINT_URL=
