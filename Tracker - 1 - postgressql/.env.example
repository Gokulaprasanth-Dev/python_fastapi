APP_NAME=Trackr
APP_VERSION=1.0.0
DEBUG=false

# ── MongoDB ────────────────────────────────────────────────────────────────
# Use an Atlas URI for production (supports transactions).
# For local dev with a standalone mongod, set MONGO_TRANSACTIONS_ENABLED=false.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGO_DB=trackr_dev
MONGO_TRANSACTIONS_ENABLED=true

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong random secret before deploying:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_real_32_plus_char_secret_before_running
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AWS S3 / MinIO ─────────────────────────────────────────────────────────
# Leave key/secret blank to use IAM instance-profile auth on EC2/ECS.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=<your-bucket-name>
# Leave blank for real AWS S3. Set to MinIO endpoint for local dev:
# AWS_ENDPOINT_URL=http://localhost:9100
AWS_ENDPOINT_URL=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to deny all
# cross-origin requests (recommended for production APIs without a frontend).
# Example: CORS_ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]
CORS_ALLOWED_ORIGINS=[]

# ── Trusted hosts ──────────────────────────────────────────────────────────
# Comma-separated list of allowed Host header values.
# Leave empty to skip enforcement (local dev).
# Example: TRUSTED_HOSTS=["api.example.com","*.example.com"]
TRUSTED_HOSTS=[]
