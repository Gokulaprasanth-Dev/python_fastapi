APP_NAME=Trackr
APP_VERSION=1.0.0
DEBUG=false

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://trackr:trackr@localhost:5432/trackr_dev

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong random secret before deploying:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_real_32_plus_char_secret_before_running
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AWS S3 / MinIO ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=<your-bucket-name>
# Leave blank for real AWS S3. Set to MinIO endpoint for local dev:
# AWS_ENDPOINT_URL=http://localhost:9100
AWS_ENDPOINT_URL=

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=[]

# ── Trusted hosts ──────────────────────────────────────────────────────────
TRUSTED_HOSTS=[]
